<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    Night theme for PrivacyShield (AMOLED optimized).
    Same as day theme since we use Compose for theming.
    -->
    <style name="Theme.PrivacyShield" parent="Theme.Material3.Dark.NoActionBar">
        <!-- AMOLED black background -->
        <item name="android:windowBackground">@android:color/black</item>
        
        <!-- Transparent system bars for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- Edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        
        <!-- Light status bar icons for dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>