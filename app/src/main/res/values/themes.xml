<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    Base theme for PrivacyShield.
    Minimal XML theme as the actual theming is done in Jetpack Compose.
    This theme is used for the splash screen and Activity window.
    -->
    <style name="Theme.PrivacyShield" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Window background for splash/startup -->
        <item name="android:windowBackground">@android:color/black</item>
        
        <!-- Status bar and navigation bar colors -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- Edge-to-edge display -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        
        <!-- Light status bar icons for dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>